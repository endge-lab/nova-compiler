{
  "name": "@endge/nova-compiler",
  "private": false,
  "version": "0.2.0",
  "type": "module",
  "module": "./dist/nova-compiler.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nova-compiler.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "dev": "vite build --watch",
    "dev:watch": "vite build --watch",
    "build": "vite build",
    "test": "vitest run --config vite.config.ts"
  },
  "dependencies": {
    "@babel/parser": "^7.29.3",
    "@endge/nova": "workspace:*",
    "@endge/nova-ui-kit": "workspace:*",
    "@vue/compiler-dom": "^3.5.34",
    "@vue/compiler-sfc": "^3.5.34"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.2.4"
  }
}
